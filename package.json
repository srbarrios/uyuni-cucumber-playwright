{
  "author": "Oscar Barrios",
  "license": "MIT",
  "name": "playwright-cucumber-skeleton",
  "version": "1.0.0",
  "description": "This project's goal is to establish a baseline project for using Playwright with Cucumber.",
  "main": "index.js",
  "scripts": {
    "cucumber": "NODE_OPTIONS=\"--no-warnings\" npx cucumber-js --loader ts-node/esm --config cucumber.cjs",
    "cucumber:sanity_check": "npm run cucumber -- --profile sanity_check",
    "cucumber:core": "npm run cucumber -- --profile core",
    "cucumber:reposync": "npm run cucumber -- --profile reposync",
    "cucumber:init_clients": "npm run cucumber -- --profile init_clients",
    "cucumber:proxy": "npm run cucumber -- --profile proxy",
    "cucumber:finishing": "npm run cucumber -- --profile finishing"
  },
  "type": "module",
  "keywords": [],
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.5",
    "@types/tmp": "^0.2.6",
    "@types/validator": "^13.15.10",
    "@types/xml2js": "^0.4.14",
    "@types/xmlrpc": "^1.3.10",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "js-yaml": "4.1.1",
    "pg": "^8.20.0",
    "redis": "^5.11.0",
    "ssh-config": "5.0.4",
    "ssh2": "1.15.0",
    "tmp": "^0.2.5",
    "validator": "^13.15.26",
    "xml2js": "^0.6.2",
    "xmlrpc": "^1.3.2"
  }
}
